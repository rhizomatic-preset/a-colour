# Dependencies
node_modules/
.pnp/
.pnp.js

# pnpm local store (lockfile itself is committed)
.pnpm-store/

# Build / dist (if applicable)
dist/
build/
.vite/
*.tsbuildinfo

# Environment
.env
.env.*
!.env.example

# IDE
.vscode/
.idea/

# Claude Code (agent worktrees + task cache)
.claude/

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# pnpm metadata files in node_modules
node_modules/.pnpm/*.yaml
node_modules/.pnpm/*.json
node_modules/.pnpm/lock.yaml

# Misc
.cache/
.temp/

# Build-time model / embedding caches (GloVe zips, ONNX weights, etc.).
