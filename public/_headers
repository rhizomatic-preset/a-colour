# Cloudflare Pages headers. Vite emits content-hashed filenames into /assets/,
# and the PWA's word-encoder model never changes for a given URL — both groups
# are safe to cache aggressively. HTML and the service worker stay short-lived
# so updates land on the next visit.

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/word-encoder/*
  Cache-Control: public, max-age=31536000, immutable

/colour-embeddings.bin
  Cache-Control: public, max-age=31536000, immutable

/sw.js
  Cache-Control: public, max-age=0, must-revalidate

/registerSW.js
  Cache-Control: public, max-age=0, must-revalidate

/manifest.webmanifest
  Cache-Control: public, max-age=3600
